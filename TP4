.box {
background-color: #2b3436;
padding:10px ;
border-radius: 10px;
text-align: center;
transition: transform 0.3s ease;
overflow: hidden;
position: relative;
display:flex ;
align-items: center;

}

.box:hover {
transform: scale( 1.05  ) ; 
}
.container {
 display: grid;
 grid-template-columns:1fr 1fr 1fr ;
 gap:2px ;
 justify-content: center;
 gap: 20px;
 margin: auto;
 text-shadow: #2b3436;
} 
.container img {
width: 200px;
height:300px ;
border-radius: 10px;

}
.box1 {grid-column:1/2;
    grid-row: 1/2 ;
}
.box2{grid-column:2/4;
    grid-row: 1/2;
}
.box3{grid-column:1/2;
    grid-row: 2/3;} 

.box4{grid-column:2/3;
    grid-row: 2/3;}

.box5{grid-column:3/4;
    grid-row:2/3 }

.box6{grid-column:1/4;
    grid-row: 3/4;}
.box button {
margin-top:auto;
padding: 9px 10px;
border-radius: 999px;
font-size: 15px;
font-weight: 600;
cursor: pointer;
background-color: rgb(76, 20, 20);
text-align: center;

}
.box p {
font-size:    20px;
font-family: 'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;
line-height: normal;
text-align: center;
color: aliceblue;

}
.box img {
height: 250px;
max-width:330px ;
width: 100%;
object-fit: cover;

}
